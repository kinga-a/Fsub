{
  "buildCommand": "",
  "outputDirectory": ".",
  "nodeVersion": "20.18.0",
  "cloudFunctions": {
    "nodejs": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/api/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
