{
  "buildCommand": "",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/*",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "schedules": [
    {
      "name": "notify-cron",
      "cron": "0 19 * * *",
      "path": "/api/notify-cron",
      "method": "POST",
      "timezone": "Asia/Shanghai"
    }
  ]
}
